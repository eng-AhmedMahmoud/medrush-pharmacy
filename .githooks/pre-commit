#!/usr/bin/env bash
# Universal secret-scan pre-commit hook.
# Install:    git config --global core.hooksPath ~/.git-hooks
# Bypass:     SKIP_SECRET_SCAN=1 git commit ...   (only for false positives)

if [ "${SKIP_SECRET_SCAN:-0}" = "1" ]; then
  echo "⚠️  SKIP_SECRET_SCAN=1 — secret scan bypassed."
  exit 0
fi

RED=$'\e[31m'; YEL=$'\e[33m'; BLD=$'\e[1m'; RST=$'\e[0m'

# Staged files (added/copied/modified/renamed), excluding deletions.
FILES_RAW=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$FILES_RAW" ]; then exit 0; fi
# Newline-delimited; pipe through xargs-safe array using IFS.
OLD_IFS=$IFS
IFS=$'\n'
set -f
FILES=($FILES_RAW)
set +f
IFS=$OLD_IFS

FAIL=0
report() { printf '%s\n' "$1"; FAIL=1; }

# 1. Block dangerous paths outright.
for f in "${FILES[@]}"; do
  case "$f" in
    .env|.env.local|.env.*.local|*.pem|*.key|id_rsa|id_rsa.pub|*.p12|*.pfx|credentials.json|service-account*.json|*-keyfile.json)
      report "${RED}${BLD}✗ refusing to commit sensitive path:${RST} $f" ;;
  esac
done

# 2. Pattern scan of staged content (diff additions only).
DIFF=$(git diff --cached --no-color -U0 -- "${FILES[@]}")

scan() {
  local label="$1" pattern="$2"
  local hits
  hits=$(printf '%s' "$DIFF" | grep -nE "^\+" | grep -nE -- "$pattern" || true)
  if [ -n "$hits" ]; then
    report "${RED}${BLD}✗ ${label}${RST}"
    printf '%s\n' "$hits" | sed 's/^/    /' | head -10
  fi
}

scan "MongoDB URI with embedded credentials"  'mongodb(\+srv)?://[^[:space:]/]*:[^@[:space:]/]+@'
scan "AWS access key id"                       '(^|[^A-Z0-9])AKIA[0-9A-Z]{16}([^A-Z0-9]|$)'
scan "AWS secret key assignment"               '(aws_secret_access_key|AWS_SECRET_ACCESS_KEY)[[:space:]]*[:=][[:space:]]*[A-Za-z0-9/+=]{40}'
scan "Slack token"                             'xox[abprs]-[A-Za-z0-9-]{10,}'
scan "Stripe live secret"                      'sk_live_[A-Za-z0-9]{24,}'
scan "GitHub PAT"                              'gh[pousr]_[A-Za-z0-9]{36,}'
scan "GitLab PAT"                              'glpat-[A-Za-z0-9_-]{20,}'
scan "Google API key"                          'AIza[0-9A-Za-z_-]{35}'
scan "Private key block"                       '-----BEGIN ([A-Z]+ )?PRIVATE KEY-----'
scan "JWT signed token (3-part)"               'eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
scan "Generic password/secret/token literal"   '(password|passwd|secret|api[_-]?key|token)[[:space:]]*[:=][[:space:]]*["'\''`][^"'\''`[:space:]]{12,}["'\''`]'
scan "Cloudflare R2 secret-shaped hex (64 hex)" '[A-Za-z0-9_-]{0,40}(secret|key)[A-Za-z0-9_-]{0,10}[[:space:]]*[:=][[:space:]]*[a-f0-9]{64}'

if [ $FAIL -ne 0 ]; then
  echo
  echo "${YEL}${BLD}Pre-commit secret scan blocked this commit.${RST}"
  echo "  - Move the value into a gitignored env file."
  echo "  - If certain it's a false positive: ${BLD}SKIP_SECRET_SCAN=1 git commit ...${RST}"
  exit 1
fi

exit 0
